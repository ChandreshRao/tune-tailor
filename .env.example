# Gemini API Key for Intent Extraction
GEMINI_API_KEY=your_gemini_api_key_here

# Local folder where your songs are stored
SONGS_PATH=./songs

# The public URL of your server (zrok, ngrok, or cloudflare)
BASE_URL=https://your-name.share.zrok.io

# Preferred Gemini Models (comma-separated, in order of priority)
GEMINI_MODELS=gemini-2.0-flash,gemini-1.5-flash,gemini-1.5-pro
